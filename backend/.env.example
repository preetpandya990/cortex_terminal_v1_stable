# Cortex AI — Environment Variables
# ====================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to source control.
#
# Generate SECRET_KEY:    openssl rand -hex 32
# Generate UPSTOX tokens: https://developer.upstox.com

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | staging | production
DEBUG=false                     # Set true only in development
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://cortex:CHANGE_ME@localhost:5432/cortex_db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis ──────────────────────────────────────────────────────────────────────
# Format: redis://HOST:PORT/DB_INDEX
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Security ───────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_32_BYTE_RANDOM_HEX

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. NEVER use ["*"] in production.
# Example: ["https://app.cortex.in","https://staging.cortex.in"]
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# ── Upstox ─────────────────────────────────────────────────────────────────────
# Obtain from https://developer.upstox.com
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
UPSTOX_BASE_URL=https://api.upstox.com/v2
UPSTOX_WS_URL=wss://api.upstox.com/v2/feed/market-data-feed
UPSTOX_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz

# ── ML System ──────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python backend/scripts/generate_ml_encryption_key.py
ML_MODEL_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_FROM_SCRIPT

# Model storage directory (relative to backend/)
ML_MODEL_STORAGE_PATH=ml_models

# Rate limits for ML endpoints (format: "count/period")
ML_RATE_LIMIT_PREDICT=10/minute      # Single prediction endpoint
ML_RATE_LIMIT_BATCH=5/minute         # Batch prediction endpoint
ML_RATE_LIMIT_ENSEMBLE=5/minute      # Ensemble prediction endpoint

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_SCANNER=10/minute
RATE_LIMIT_SEARCH=60/minute
RATE_LIMIT_MARKET_DATA=120/minute

# ── Caching TTLs (seconds) ─────────────────────────────────────────────────────
CACHE_TTL_SCANNER=60
CACHE_TTL_INSTRUMENTS=300
CACHE_TTL_LIVE_QUOTE=1
CACHE_TTL_MARKET_STATUS=30

# ── Ingestion ──────────────────────────────────────────────────────────────────
BULK_INSERT_BATCH_SIZE=1000

# ── Observability ──────────────────────────────────────────────────────────────
# Optional: Sentry DSN for error tracking in staging/production
# SENTRY_DSN=https://your-key@sentry.io/project-id

# ── NSE Market Calendar ────────────────────────────────────────────────────────
# Official NSE holiday API (used to avoid trading on holidays)
NSE_HOLIDAY_API_URL=https://www.nseindia.com/api/holiday-master?type=trading
# Local cache path for NSE holiday payload
NSE_HOLIDAY_CACHE_FILE=backend/.cache/nse_holidays.json
# Market hours (IST)
NSE_MARKET_OPEN_IST=09:15
NSE_MARKET_CLOSE_IST=15:30
