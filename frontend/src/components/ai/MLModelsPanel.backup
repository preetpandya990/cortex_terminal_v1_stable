/**
 * ML Models Panel Component
 * Displays all models with state, drift score, accuracy metrics, and admin controls
 */
import * as React from "react";
import { format } from "date-fns";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog";
import { useModels, useDriftReports, useUpdateModelState } from "@/hooks/useModels";
import { ModelState, type ModelFilters, type MLModel } from "@/types/models";
import {
  RefreshCw,
  AlertTriangle,
  CheckCircle,
  Activity,
  TrendingUp,
  Settings,
} from "lucide-react";

interface MLModelsPanelProps {
  className?: string;
  isAdmin?: boolean;
}

export function MLModelsPanel({ className, isAdmin = false }: MLModelsPanelProps) {
  const [filters, setFilters] = React.useState<ModelFilters>({
    page: 1,
    limit: 20,
  });
  const [selectedModel, setSelectedModel] = React.useState<MLModel | null>(null);
  const [showStateDialog, setShowStateDialog] = React.useState(false);
  const [newState, setNewState] = React.useState<ModelState | null>(null);

  const { data, isLoading, refetch, isRefetching } = useModels(filters);
  const { data: driftData, isLoading: isDriftLoading } = useDriftReports();
  const updateModelState = useUpdateModelState();

  const getStateColor = (state: ModelState) => {
    switch (state) {
      case ModelState.LIVE:
        return "bg-green-500/10 text-green-700 dark:text-green-400 border-green-500/20";
      case ModelState.PAPER:
        return "bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-500/20";
      case ModelState.SHADOW:
        return "bg-yellow-500/10 text-yellow-700 dark:text-yellow-400 border-yellow-500/20";
      case ModelState.RETIRED:
        return "bg-gray-500/10 text-gray-700 dark:text-gray-400 border-gray-500/20";
    }
  };

  const getStateLabel = (state: ModelState) => {
    return state?.charAt(0).toUpperCase() + state?.slice(1);
  };

  const getDriftForModel = (modelId: number) => {
    if (!driftData) return null;
    return driftData.reports.find((r) => r.model_id === modelId);
  };

  const getDriftColor = (driftScore: number) => {
    if (driftScore >= 0.7) return "text-red-600 dark:text-red-400";
    if (driftScore >= 0.4) return "text-yellow-600 dark:text-yellow-400";
    return "text-green-600 dark:text-green-400";
  };

  const handleStateChange = (model: MLModel, state: ModelState) => {
    setSelectedModel(model);
    setNewState(state);
    setShowStateDialog(true);
  };

  const confirmStateChange = async () => {
  const confirmStateChange = async () => {
    if (!selectedModel || !newState) return;
    if (!selectedModel || !newState) return;


    try {
    try {
      await updateModelState.mutateAsync({
      await updateModelState.mutateAsync({
        modelId: selectedModel.model_id,
        modelId: selectedModel.model_id,
        data: {
          new_state: newState,
        reason: `State transition from ${selectedModel.deployment_state} to ${newState}`,
        reason: `State transition from ${selectedModel.deployment_state} to ${newState}`,
      });
      });
      setShowStateDialog(false);
      setShowStateDialog(false);
      setSelectedModel(null);
      setSelectedModel(null);
      setNewState(null);
      setNewState(null);
    } catch (error) {
    } catch (error) {
      console.error("Failed to update model state:", error);
      console.error("Failed to update model state:", error);
    }
    }
  };
  };

  if (isLoading) {
    return (
      <Card className={className}>
        <CardHeader>
          <CardTitle>ML Models</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="flex items-center justify-center py-8">
            <RefreshCw className="size-6 animate-spin text-muted-foreground" />
          </div>
        </CardContent>
      </Card>
    );
  }

  if (!data || data.models.length === 0) {
    return (
      <Card className={className}>
        <CardHeader>
          <CardTitle>ML Models</CardTitle>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-muted-foreground">No models registered</p>
        </CardContent>
      </Card>
    );
  }

  return (
    <>
      <Card className={className}>
        <CardHeader>
          <div className="flex items-center justify-between">
            <CardTitle>ML Models ({data.total})</CardTitle>
            <Button
              variant="outline"
              size="sm"
              onClick={() => refetch()}
              disabled={isRefetching}
            >
              <RefreshCw
                className={`size-4 ${isRefetching ? "animate-spin" : ""}`}
              />
            </Button>
          </div>
        </CardHeader>
        <CardContent>
          <div className="rounded-md border">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Model</TableHead>
                  <TableHead>Type</TableHead>
                  <TableHead>Version</TableHead>
                  <TableHead>State</TableHead>
                  <TableHead>Drift</TableHead>
                  <TableHead>Accuracy</TableHead>
                  <TableHead>Last Prediction</TableHead>
                  {isAdmin && <TableHead>Actions</TableHead>}
                </TableRow>
              </TableHeader>
              <TableBody>
                {data.models.map((model) => {
                  const drift = getDriftForModel(model.model_id);
                  return (
                    <TableRow key={model.model_id}>
                      <TableCell className="font-medium">
                        {model.model_name}
                      </TableCell>
                      <TableCell>
                        <span className="text-sm text-muted-foreground">
                          {model.model_type}
                        </span>
                      </TableCell>
                      <TableCell>
                        <Badge variant="outline">{model.version}</Badge>
                      </TableCell>
                      <TableCell>
                        <Badge
                          variant="outline"
                          className={getStateColor(model.deployment_state)}
                        >
                          {getStateLabel(model.deployment_state)}
                        </Badge>
                      </TableCell>
                      <TableCell>
                        {drift ? (
                          <div className="flex items-center gap-2">
                            {drift.drift_detected && (
                              <AlertTriangle className="size-4 text-red-600" />
                            )}
                            <span
                              className={`text-sm font-medium ${getDriftColor(drift.drift_score)}`}
                            >
                              {(drift.drift_score * 100).toFixed(1)}%
                            </span>
                          </div>
                        ) : (
                          <span className="text-sm text-muted-foreground">
                            No data
                          </span>
                        )}
                      </TableCell>
                      <TableCell>
                        <div className="space-y-1">
                          {model.accuracy_metrics && Object.entries(model.accuracy_metrics)
                            .slice(0, 2)
                            .map(([key, value]) => (
                              <div
                                key={key}
                                className="flex items-center gap-2 text-xs"
                              >
                                <span className="text-muted-foreground">
                                  {key}:
                                </span>
                                <span className="font-medium">
                                  {typeof value === "number"
                                    ? value.toFixed(3)
                                    : value}
                                </span>
                              </div>
                            ))}
                        </div>
                      </TableCell>
                      <TableCell>
                        {model.last_prediction_at ? (
                          <span className="text-sm text-muted-foreground">
                            {format(
                              new Date(model.last_prediction_at),
                              "MMM d, HH:mm"
                            )}
                          </span>
                        ) : (
                          <span className="text-sm text-muted-foreground">
                            Never
                          </span>
                        )}
                      </TableCell>
                      {isAdmin && (
                        <TableCell>
                          <div className="flex gap-1">
                            {model.deployment_state !== ModelState.SHADOW && (
                              <Button
                                variant="ghost"
                                size="sm"
                                onClick={() =>
                                  handleStateChange(model, ModelState.SHADOW)
                                }
                                title="Move to Shadow"
                              >
                                <Activity className="size-4" />
                              </Button>
                            )}
                            {model.deployment_state !== ModelState.PAPER && (
                              <Button
                                variant="ghost"
                                size="sm"
                                onClick={() =>
                                  handleStateChange(model, ModelState.PAPER)
                                }
                                title="Move to Paper"
                              >
                                <CheckCircle className="size-4" />
                              </Button>
                            )}
                            {model.deployment_state !== ModelState.LIVE && (
                              <Button
                                variant="ghost"
                                size="sm"
                                onClick={() =>
                                  handleStateChange(model, ModelState.LIVE)
                                }
                                title="Move to Live"
                              >
                                <TrendingUp className="size-4" />
                              </Button>
                            )}
                          </div>
                        </TableCell>
                      )}
                    </TableRow>
                  );
                })}
              </TableBody>
            </Table>
          </div>

          {/* Drift Alerts Section */}
          {!isDriftLoading &&
            driftData &&
            driftData.reports.some((r) => r.drift_detected) && (
              <div className="mt-6">
                <h4 className="mb-3 flex items-center gap-2 text-sm font-semibold">
                  <AlertTriangle className="size-4 text-red-600" />
                  Drift Alerts
                </h4>
                <div className="space-y-2">
                  {driftData.reports
                    .filter((r) => r.drift_detected)
                    .map((report) => (
                      <div
                        key={report.report_id}
                        className="flex items-center justify-between rounded-lg border border-red-500/20 bg-red-500/10 p-3"
                      >
                        <div>
                          <div className="text-sm font-medium text-red-700 dark:text-red-400">
                            {report.model_name}
                          </div>
                          <div className="text-xs text-muted-foreground">
                            Detected:{" "}
                            {format(
                              new Date(report.detected_at),
                              "MMM d, HH:mm"
                            )}
                          </div>
                        </div>
                        <div className="text-right">
                          <div className="text-sm font-semibold text-red-700 dark:text-red-400">
                            {(report.drift_score * 100).toFixed(1)}% drift
                          </div>
                        </div>
                      </div>
                    ))}
                </div>
              </div>
            )}
        </CardContent>
      </Card>

      {/* State Change Confirmation Dialog */}
      <Dialog open={showStateDialog} onOpenChange={setShowStateDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Confirm State Change</DialogTitle>
            <DialogDescription>
              Are you sure you want to change the deployment state of{" "}
              <strong>{selectedModel?.model_name}</strong> from{" "}
              <strong>{selectedModel?.deployment_state}</strong> to{" "}
              <strong>{newState}</strong>?
            </DialogDescription>
          </DialogHeader>
          <DialogFooter>
            <Button
              variant="outline"
              onClick={() => setShowStateDialog(false)}
            >
              Cancel
            </Button>
            <Button
              onClick={confirmStateChange}
              disabled={updateModelState.isPending}
            >
              {updateModelState.isPending ? (
                <>
                  <RefreshCw className="mr-2 size-4 animate-spin" />
                  Updating...
                </>
              ) : (
                "Confirm"
              )}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </>
  );
}
