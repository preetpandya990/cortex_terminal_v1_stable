# Cortex AI Unified — Environment Variables
# ==========================================
# Copy this file:   cp .env.example .env
# Fill in all REQUIRED values before running docker compose up.
# NEVER commit .env to source control.
#
# Variable resolution order (Docker Compose):
#   1. Shell environment   2. This .env file   3. Inline defaults

# ── PostgreSQL (TimescaleDB) ───────────────────────────────────────────────────
POSTGRES_USER=cortex
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=cortex_db

# ── Database URL ───────────────────────────────────────────────────────────────
# For local development outside Docker:
DATABASE_URL=postgresql+asyncpg://cortex:CHANGE_ME_strong_password_here@localhost:5433/cortex_db

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis ──────────────────────────────────────────────────────────────────────
# For local dev outside Docker: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=cortex-ai-unified
APP_VERSION=1.0.0
ENVIRONMENT=development         # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Security — JWT ─────────────────────────────────────────────────────────────
# REQUIRED. Generate with:   openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_32_BYTE_RANDOM_HEX

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# REQUIRED. Generate with:   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ML_MODEL_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list. Never use "*" — the app will refuse to start.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ── Upstox API ─────────────────────────────────────────────────────────────────
# Obtain from https://developer.upstox.com/apps
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
UPSTOX_BASE_URL=https://api.upstox.com/v2
UPSTOX_WS_URL=wss://api.upstox.com/v2/feed/market-data-feed
UPSTOX_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz

# ── Worker Process ─────────────────────────────────────────────────────────────
ENABLE_BACKGROUND_TASKS=true
WORKER_SHUTDOWN_TIMEOUT=30

# ── RSS Ingestion ──────────────────────────────────────────────────────────────
RSS_MIN_POLL_SECONDS=300
RSS_MAX_POLL_SECONDS=600
RSS_CONCURRENCY=5
RSS_POLL_JITTER_SECONDS=60
RSS_DEDUP_DISABLED=false

# ── Regime Detection ───────────────────────────────────────────────────────────
ACTIVE_SYMBOLS_REFRESH_SECONDS=300
REGIME_IDLE_SLEEP_SECONDS=60

# ── Ollama (Local LLM) ─────────────────────────────────────────────────────────
# For local dev outside Docker: http://localhost:11434
# Inside Docker: http://ollama:11434 (set automatically)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# ── OpenAI (Optional Fallback) ─────────────────────────────────────────────────
# Leave empty to disable GPT-4o fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# ── ML Models ──────────────────────────────────────────────────────────────────
FINBERT_MODEL_PATH=ProsusAI/finbert
TRANSFORMERS_CACHE_DIR=./models/cache
MODEL_DEVICE=cpu                # cpu | cuda

# ── Safety Thresholds ──────────────────────────────────────────────────────────
LOSS_LIMIT_THRESHOLD=-5000.0
VOLATILITY_SPIKE_MULTIPLIER=3.0
SIGNAL_FREQUENCY_THRESHOLD=100

# ── Observability ──────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_SCANNER=10/minute
RATE_LIMIT_SEARCH=60/minute
RATE_LIMIT_MARKET_DATA=120/minute
RATE_LIMIT_ML_PREDICT=100/minute
RATE_LIMIT_KILL_SWITCH=5/minute

# ── Cache TTLs (seconds) ───────────────────────────────────────────────────────
CACHE_TTL_SCANNER=60
CACHE_TTL_INSTRUMENTS=300
CACHE_TTL_LIVE_QUOTE=1
CACHE_TTL_MARKET_STATUS=30
CACHE_TTL=3600

# ── NSE Market Calendar ────────────────────────────────────────────────────────
NSE_HOLIDAY_API_URL=https://www.nseindia.com/api/holiday-master?type=trading
NSE_HOLIDAY_CACHE_FILE=.cache/nse_holidays.json
NSE_MARKET_OPEN_IST=09:15
NSE_MARKET_CLOSE_IST=15:30

# ── Ingestion ──────────────────────────────────────────────────────────────────
BULK_INSERT_BATCH_SIZE=1000

# ── Evidently (Drift Detection) ────────────────────────────────────────────────
EVIDENTLY_WORKSPACE=./evidently_workspace
EVIDENTLY_PROJECT_NAME=cortex-ai-monitoring
